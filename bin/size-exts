#!/usr/bin/env ruby

require 'fileutils'
require 'pathname'
require_relative 'common'

def analyze_directory(path, list_label = nil)
  extensions = Hash.new { |h, k| h[k] = { count: 0, size: 0, files: [] } }
  base_path = Pathname.new(path)
  
  Dir.glob("#{path}/**/*").each do |file|
    next unless File.file?(file)
    
    ext = Common::Extensions.detect(file)
    
    extensions[ext][:count] += 1
    extensions[ext][:size] += File.size(file)
    # Store relative path to make output more readable
    extensions[ext][:files] << Pathname.new(file).relative_path_from(base_path).to_s
  end
  
  # Calculate total size for percentages
  total_size = extensions.values.sum { |stats| stats[:size] }
  
  # Prepare table components
  title = "File extensions in: #{path}"
  headers = ["Label", "Extension", "Size (MB)", "Percent", "Count", "Avg (MB)"]
  
  # Track extension info for potential listing
  list_ext = nil
  list_files = nil
  
  # Sort by size in descending order and assign labels for body rows
  rows = extensions.to_a.sort_by { |_, stats| -stats[:size] }.map.with_index do |(ext, stats), i|
    label = ('A'.ord + i).chr
    avg_size = stats[:size] / stats[:count]
    percent = stats[:size] * 100.0 / total_size
    
    # Store info for listing if label matches
    if list_label && label == list_label.upcase
      list_ext = ext
      list_files = stats[:files]
    end
    
    [
      label,
      ext,
      Common::TableFormatter.human_size_mb(stats[:size]),
      "%.1f" % percent,
      stats[:count].to_s,
      Common::TableFormatter.human_size_mb(avg_size, 2)
    ]
  end

  # Calculate totals
  total_count = extensions.values.sum { |stats| stats[:count] }
  total_avg = total_size / total_count
  totals = [
    "Total",
    "",
    Common::TableFormatter.human_size_mb(total_size),
    "",
    total_count.to_s,
    Common::TableFormatter.human_size_mb(total_avg, 2)
  ]

  # Only align numeric columns (Size, Percent, Count, Avg)
  Common::TableFormatter.format_table(title, headers, rows, totals, [2, 3, 4, 5])
  
  # If we have files to list, show them after the table
  if list_files
    puts
    puts "#{list_label}        Files with extension '#{list_ext}':"
    puts
    list_files.sort.each do |file|
      puts file
    end
  end
end

if ARGV.empty?
  puts "Usage: #{$0} <directory> [label]"
  puts "  If label (A-Z) is provided, lists all files with that extension"
  exit 1
end

analyze_directory(ARGV[0], ARGV[1])
