#!/usr/bin/env bash

# rust
# run [n] [prefix] [cores]

n=${1:-}
prefix=${2:-}
cores=${3:-}

cd "$(dirname "$0")"
top=$(git rev-parse --show-toplevel)

# Set build directory
export CARGO_TARGET_DIR="_build"

# Rebuild if binary is missing or any source is newer
if [[ ! -f _build/release/perms ]] || [[ -n "$(find src Cargo.toml -newer _build/release/perms 2>/dev/null | head -1)" ]]; then
    echo "Building Rust..."
    cargo build --release || exit 1
    # Clean up build artifacts, keeping only the binary
    find _build -type f ! -name "perms" -delete 2>/dev/null || true
    find _build -type d -empty -delete 2>/dev/null || true
fi

"$top/bin/log-run" ./_build/release/perms $n $prefix $cores
