#!/usr/bin/env bash

# kotlin-native
# run [n] [prefix] [cores]
#
# Requires full Xcode installation (not just Command Line Tools)
# for kotlinc-native to query SDK versions via xcodebuild.

n=${1:-}
prefix=${2:-}
cores=${3:-}

cd "$(dirname "$0")"
top=$(git rev-parse --show-toplevel)

export JAVA_OPTS="--enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow"

kotlinc-native -opt -o perms \
    ../src/Answers.kt \
    ../src/Loops.kt \
    ../src/Perms.kt \
    ../src/Tarjan.kt \
    ../src/Worker.kt \
    Parallel.kt || exit 1

"$top/bin/log-run" ./perms.kexe $n $prefix $cores
